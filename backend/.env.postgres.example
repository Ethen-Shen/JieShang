# Vercel Postgres 环境变量
# 复制此文件为 .env.local 并填入实际值

# PostgreSQL连接字符串（从Vercel Storage获取）
DATABASE_POSTGRES_URL=postgres://default:xxxxxxxxxx@xxxxx.postgres.vercel-storage.com:5432/verceldb?sslmode=require

# JWT密钥（用于认证）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 服务器端口（Vercel会忽略这个）
PORT=3001
