{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "server.postgres.js",
      "use": "@vercel/node",
      "config": {
        "outputDirectory": "api"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/public/(.*)",
      "dest": "/server.postgres.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.postgres.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
